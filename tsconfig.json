{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@beluga/sdk": ["../beluga/packages/sdk/src"]
    }
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "dist"]
}
